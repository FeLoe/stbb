:root{--color-primary:200 146 42}body{font-family:lato,sans-serif}h1,h2,h3,h4,h5,h6,.stbb-upcoming-title,.stbb-section-header h1,nav{font-family:oswald,sans-serif;letter-spacing:.03em}.stbb-hero{width:100%;height:80vh;min-height:400px;overflow:hidden;display:flex;align-items:center;justify-content:center;background:#1c1917}@media(max-width:640px){.stbb-hero{height:auto;min-height:unset}}.stbb-hero-img{width:100%;height:100%;object-fit:cover;object-position:center;display:block}@media(max-width:640px){.stbb-hero-img{height:auto;object-fit:initial}}.stbb-upcoming{padding:3rem 1rem;background:#f3f4f6}html.dark .stbb-upcoming{background:#1c1917}.stbb-upcoming-inner{max-width:720px;margin:0 auto}.stbb-upcoming-title{font-size:1.8rem;font-weight:700;margin-bottom:1.5rem;text-align:center;color:#111}html.dark .stbb-upcoming-title{color:#fff}.upcoming-events-list{display:flex;flex-direction:column;gap:.75rem}.upcoming-event-card{display:flex;align-items:center;gap:1.25rem;padding:1rem 1.25rem;background:rgba(0,0,0,4%);border-left:3px solid #c8922a;border-radius:4px;text-decoration:none!important;color:inherit!important;transition:background .2s,border-color .2s}html.dark .upcoming-event-card{background:rgba(255,255,255,5%)}.upcoming-event-card:hover{background:rgba(0,0,0,9%);border-left-color:#e8a83a}html.dark .upcoming-event-card:hover{background:rgba(255,255,255,.1)}.event-date-badge{display:flex;flex-direction:column;align-items:center;min-width:48px;text-align:center}.event-date-badge .edb-day{font-size:2rem;font-weight:700;line-height:1;color:#c8922a}.event-date-badge .edb-month{font-size:.68rem;text-transform:uppercase;letter-spacing:1px;color:#666;margin-top:2px}html.dark .event-date-badge .edb-month{color:#bbb}.event-date-badge .edb-year{font-size:.62rem;color:#888;margin-top:1px}.event-details{flex:1;display:flex;flex-direction:column;gap:.2rem}.event-details .event-name{font-size:1.05rem;font-weight:600;color:inherit}.event-details .event-location{font-size:.82rem;color:#666}html.dark .event-details .event-location{color:#aaa}.event-arrow{color:#999;font-size:1.2rem}html.dark .event-arrow{color:#555}.stbb-see-all{margin-top:1.5rem;text-align:center}.stbb-see-all a{color:#c8922a;text-decoration:none;font-weight:600;font-size:.9rem;letter-spacing:.5px}.stbb-see-all a:hover{color:#e8a83a}.stbb-no-events{text-align:center;color:#666}html.dark .stbb-no-events{color:#aaa}.stbb-section-header{padding:2rem 1rem 1rem;max-width:900px;margin:0 auto}.stbb-section-header h1{font-size:2rem;font-weight:700;margin-bottom:.5rem}.stbb-section-intro{color:#aaa;margin-top:.5rem}.stbb-events-wrapper{max-width:900px;margin:0 auto;padding:1rem 1rem 3rem}#event-year-tabs{display:flex;flex-wrap:wrap;gap:.5rem;margin-bottom:2rem}.event-year-btn{padding:.4rem 1rem;min-width:70px;border:1px solid #ccc;background:0 0;color:#555;border-radius:4px;cursor:pointer;font-size:.9rem;transition:all .15s}html.dark .event-year-btn{border-color:#444;color:#bbb}.event-year-btn:hover{border-color:#c8922a;color:#c8922a}.event-year-btn.active{background:#c8922a;border-color:#c8922a;color:#fff;font-weight:600}.stbb-gallery-wrapper{columns:3 280px;gap:.5rem;padding:1rem;max-width:1200px;margin:0 auto}@media(max-width:600px){.stbb-gallery-wrapper{columns:2 140px}}.stbb-gallery-item{display:block;margin-bottom:.5rem;break-inside:avoid;overflow:hidden;border-radius:3px}.stbb-gallery-item img{width:100%;height:auto;display:block;transition:opacity .2s;cursor:pointer}.stbb-gallery-item img:hover{opacity:.85}.stbb-contact-wrapper{max-width:640px;margin:2rem auto;padding:0 1rem 3rem}.stbb-contact-form{display:flex;flex-direction:column;gap:1rem;margin-top:1.5rem}.stbb-contact-form label{display:flex;flex-direction:column;gap:.3rem;font-size:.9rem;color:#bbb}.stbb-contact-form input,.stbb-contact-form textarea{background:rgba(255,255,255,7%);border:1px solid #444;border-radius:4px;color:#eee;padding:.6rem .8rem;font-size:.95rem;width:100%}.stbb-contact-form input:focus,.stbb-contact-form textarea:focus{outline:none;border-color:#c8922a}.stbb-contact-form textarea{min-height:140px;resize:vertical}.stbb-contact-form button[type=submit]{align-self:flex-start;padding:.6rem 1.8rem;background:#c8922a;border:none;border-radius:4px;color:#fff;font-size:.95rem;font-weight:600;cursor:pointer;transition:background .2s}.stbb-contact-form button[type=submit]:hover{background:#e8a83a}.stbb-people-wrapper{max-width:800px;margin:0 auto;padding:1rem 1rem 3rem}.stbb-people-content{margin-top:1.5rem;font-size:.975rem;line-height:1.8}.stbb-people-content p{margin-bottom:1.4rem}.stbb-people-content p:nth-child(3){display:flex;flex-direction:column;align-items:flex-start;gap:.75rem}.stbb-people-content a[href$=".pdf"]{display:inline-block;padding:.45rem 1.2rem;border:2px solid #c8922a;border-radius:4px;color:#c8922a!important;font-weight:600;font-size:.875rem;letter-spacing:.06em;text-decoration:none!important;transition:background-color .2s,color .2s}.stbb-people-content a[href$=".pdf"]:hover{background-color:#c8922a;color:#fff!important}.stbb-people-content p:nth-child(4){margin-top:2rem;padding-top:2rem;border-top:1px solid rgba(200,146,42,.3)}.event-card-link{display:block;text-decoration:none!important;color:inherit!important;margin-bottom:.5rem}.event-card{display:flex;align-items:center;gap:1rem;padding:.75rem 1rem;background:rgba(0,0,0,3%);border-radius:4px;transition:background .15s}html.dark .event-card{background:rgba(255,255,255,4%)}.event-card:hover{background:rgba(0,0,0,7%)}html.dark .event-card:hover{background:rgba(255,255,255,9%)}.event-card-date{display:flex;flex-direction:column;align-items:center;min-width:44px;text-align:center}.event-card-date .ecd-day{font-size:1.5rem;font-weight:700;line-height:1;color:#c8922a}.event-card-date .ecd-month{font-size:.65rem;text-transform:uppercase;letter-spacing:1px;color:#888;margin-top:1px}.event-card-info{flex:1;display:flex;flex-direction:column;gap:.15rem}.event-card-info .event-card-title{font-size:.95rem;font-weight:600;color:inherit}.event-card-info .event-card-location{font-size:.78rem;color:#666}html.dark .event-card-info .event-card-location{color:#888}.stbb-post-single{max-width:760px;margin:0 auto;padding:2rem 1rem 3rem}.stbb-post-single-header{margin-bottom:1.5rem}.stbb-post-single-header h1{font-size:2rem;font-weight:700;margin-bottom:.5rem}.stbb-post-single-date{display:block;font-size:.9rem;color:#c8922a;font-weight:600}.stbb-post-single-image{margin-bottom:1.75rem;border-radius:6px;overflow:hidden}.stbb-post-single-image img{width:100%;height:auto;display:block}.stbb-post-single-body{font-size:1rem;line-height:1.75}.stbb-post-single-body p{margin-bottom:1.2rem}.stbb-post-single-body a{color:#c8922a}.stbb-post-single-link{margin-top:1.5rem}.stbb-post-single-link a{display:inline-block;padding:.5rem 1.25rem;background:#c8922a;color:#fff!important;text-decoration:none!important;border-radius:4px;font-weight:600;font-size:.9rem;transition:background .2s}.stbb-post-single-link a:hover{background:#e8a83a}.stbb-event-single{max-width:760px;margin:0 auto;padding:2rem 1rem 3rem}.stbb-event-single-header{margin-bottom:1.5rem}.stbb-event-single-header h1{font-size:2rem;font-weight:700;margin-bottom:.5rem}.stbb-event-single-meta{display:flex;flex-wrap:wrap;gap:.5rem 1.25rem;font-size:.9rem;color:#888}html.dark .stbb-event-single-meta{color:#aaa}.stbb-event-single-date{color:#c8922a;font-weight:600}.stbb-event-single-image{margin-bottom:1.75rem;border-radius:6px;overflow:hidden}.stbb-event-single-image img{width:100%;height:auto;display:block}.stbb-event-single-body{margin-bottom:1.5rem;font-size:1rem;line-height:1.75}.stbb-event-single-link{margin-top:1.5rem}.stbb-event-single-link a{display:inline-block;padding:.5rem 1.25rem;background:#c8922a;color:#fff!important;text-decoration:none!important;border-radius:4px;font-weight:600;font-size:.9rem;transition:background .2s}.stbb-event-single-link a:hover{background:#e8a83a}.stbb-songs-wrapper{max-width:680px;margin:0 auto;padding:1rem 1rem 3rem}.stbb-songs-content{margin-top:1.5rem}.stbb-songs-content p{font-size:1rem;font-weight:600;margin:1.5rem 0 .4rem;color:inherit}.stbb-songs-content p:first-child{margin-top:0}.stbb-audio-player{width:100%;height:36px;border-radius:6px;outline:none;margin:.5rem 0 1.25rem;background:rgba(255,255,255,5%);box-shadow:0 1px 4px rgba(0,0,0,.3)}.stbb-audio-player::-webkit-media-controls-panel{background:rgba(30,20,10,.55)}